{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev-server",
      "type": "shell",
      "command": "pnpm dev --host 0.0.0.0 --port 5173",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [{ "regexp": "." }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
