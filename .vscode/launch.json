{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite React: Debug App",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "app:run",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Vite React: Debug Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["test:watch"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
