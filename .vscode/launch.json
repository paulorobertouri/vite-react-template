{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Vite (Chrome)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Debug Vitest",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["test", "--", "--watch"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
